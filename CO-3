import java.util.*;



class Graph { private int vertices; private LinkedList[] adjList;

Graph(int v) {
    vertices = v;
    adjList = new LinkedList[v];

    for (int i = 0; i < v; i++) {
        adjList[i] = new LinkedList<>();
    }
}

// Add dependency edge
void addEdge(int source, int destination) {
    adjList[source].add(destination);
}

// Cycle Detection using DFS
boolean isCyclicUtil(int node, boolean visited[], boolean recStack[]) {

    visited[node] = true;
    recStack[node] = true;

    for (Integer neighbor : adjList[node]) {

        if (!visited[neighbor] &&
            isCyclicUtil(neighbor, visited, recStack))
            return true;

        else if (recStack[neighbor])
            return true;
    }

    recStack[node] = false;
    return false;
}

boolean isCyclic() {

    boolean visited[] = new boolean[vertices];
    boolean recStack[] = new boolean[vertices];

    for (int i = 0; i < vertices; i++) {

        if (isCyclicUtil(i, visited, recStack))
            return true;
    }

    return false;
}
}

public class RazorpayCI {

public static void main(String[] args) {

    
    Graph g = new Graph(4);

    
    g.addEdge(0, 1);
    g.addEdge(1, 2);
    g.addEdge(2, 3);

    
    g.addEdge(3, 1);

    if (g.isCyclic())
        System.out.println("Cycle Detected in CI Build Graph");
    else
        System.out.println("No Cycle Found");
}
}

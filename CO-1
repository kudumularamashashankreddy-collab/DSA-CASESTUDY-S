class AVLNode { int appointmentId, height; AVLNode left, right;

AVLNode(int id) {
    appointmentId = id;
    height = 1;
}
}

class AVLTree {

int height(AVLNode node) {
    if (node == null)
        return 0;
    return node.height;
}

int getBalance(AVLNode node) {
    if (node == null)
        return 0;
    return height(node.left) - height(node.right);
}

AVLNode rightRotate(AVLNode y) {
    AVLNode x = y.left;
    AVLNode T2 = x.right;

    x.right = y;
    y.left = T2;

    y.height = Math.max(height(y.left), height(y.right)) + 1;
    x.height = Math.max(height(x.left), height(x.right)) + 1;

    return x;
}

AVLNode leftRotate(AVLNode x) {
    AVLNode y = x.right;
    AVLNode T2 = y.left;

    y.left = x;
    x.right = T2;

    x.height = Math.max(height(x.left), height(x.right)) + 1;
    y.height = Math.max(height(y.left), height(y.right)) + 1;

    return y;
}

AVLNode insert(AVLNode node, int id) {

    if (node == null)
        return new AVLNode(id);

    if (id < node.appointmentId)
        node.left = insert(node.left, id);
    else if (id > node.appointmentId)
        node.right = insert(node.right, id);
    else
        return node;

    node.height = 1 + Math.max(height(node.left), height(node.right));

    int balance = getBalance(node);

    // LL Rotation
    if (balance > 1 && id < node.left.appointmentId)
        return rightRotate(node);

    // RR Rotation
    if (balance < -1 && id > node.right.appointmentId)
        return leftRotate(node);

    // LR Rotation
    if (balance > 1 && id > node.left.appointmentId) {
        node.left = leftRotate(node.left);
        return rightRotate(node);
    }

    // RL Rotation
    if (balance < -1 && id < node.right.appointmentId) {
        node.right = rightRotate(node.right);
        return leftRotate(node);
    }

    return node;
}

void inorder(AVLNode root) {
    if (root != null) {
        inorder(root.left);
        System.out.print(root.appointmentId + " ");
        inorder(root.right);
    }
}
}

public class MediFlowHospital { public static void main(String[] args) {

    AVLTree tree = new AVLTree();
    AVLNode root = null;

    int appointments[] = {105, 102, 108, 101, 103, 107, 110};

    for (int id : appointments) {
        root = tree.insert(root, id);
    }

    System.out.println("Patient Appointment IDs in Sorted Order:");
    tree.inorder(root);
}
}

